# ================================================================
# Website Analyzer — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.
# ================================================================

# ----------------------------------------------------------------
# SUPABASE  (required — auth, database, storage)
# Dashboard → project → Settings → API
# ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...        # server-only, never expose to browser

# ----------------------------------------------------------------
# UPSTASH REDIS  (required — job queue, rate limiting)
# https://console.upstash.com → Create database → REST API tab
# ----------------------------------------------------------------
UPSTASH_REDIS_URL=https://your-db.upstash.io
UPSTASH_REDIS_TOKEN=your-token

# ----------------------------------------------------------------
# ANTHROPIC (Claude)  (required — screenshot + text AI analysis)
# https://console.anthropic.com → API Keys
# ----------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ----------------------------------------------------------------
# OPENAI  (optional — can use Claude for all AI tasks instead)
# https://platform.openai.com → API keys
# ----------------------------------------------------------------
OPENAI_API_KEY=sk-...

# ----------------------------------------------------------------
# CLOUDFLARE WORKER  (required — browser automation engine)
# Deploy: wrangler deploy  (see src/workers/analyzer/)
# Secrets: wrangler secret put WORKER_AUTH_TOKEN
#          wrangler secret put WORKER_CALLBACK_SECRET
# WORKER_CALLBACK_SECRET validates callbacks from Worker → this app
# ----------------------------------------------------------------
CLOUDFLARE_WORKER_URL=https://your-worker.your-subdomain.workers.dev
CLOUDFLARE_WORKER_AUTH_TOKEN=generate-a-random-secret
WORKER_CALLBACK_SECRET=generate-a-different-random-secret

# ----------------------------------------------------------------
# STRIPE  (optional for MVP — needed for paid plan billing)
# https://dashboard.stripe.com/apikeys  (use sk_test_ keys in dev)
# Webhook secret: stripe listen --print-secret  (local dev)
#                 or Dashboard → Webhooks → signing secret (prod)
# Price IDs: Dashboard → Products → create Pro & Agency products
# ----------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRO_PRICE_ID=price_...          # Pro plan monthly price ID
STRIPE_AGENCY_PRICE_ID=price_...       # Agency plan monthly price ID
STRIPE_COMPLIANCE_PRICE_ID=price_...   # Compliance plan monthly price ID ($249/mo)

# ----------------------------------------------------------------
# RESEND  (optional — transactional email: welcome, alerts, digests)
# https://resend.com/api-keys
# EMAIL_FROM must be a verified sender domain in your Resend account.
# For quick testing you can use: onboarding@resend.dev
# ----------------------------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM=WebAnalyzer <noreply@yourdomain.com>
SUPPORT_EMAIL=support@yourdomain.com   # required — inbox that receives support chat messages

# ----------------------------------------------------------------
# SENTRY  (optional — error tracking and performance monitoring)
# https://sentry.io → New Project → Next.js → copy DSN
# SENTRY_DSN is server/edge only; NEXT_PUBLIC_SENTRY_DSN is browser
# ----------------------------------------------------------------
SENTRY_DSN=https://...@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0

# ----------------------------------------------------------------
# SECURITY  (server-only — never expose these to the browser)
# CRON_SECRET: sent as Bearer token by Vercel Cron → /api/cron/*
#   generate: openssl rand -hex 32
# API_KEY_ENCRYPTION_SECRET: AES-256-GCM key for encrypting stored
#   API key prefixes — must be exactly 32 bytes (64 hex chars)
#   generate: openssl rand -hex 32
# BLOCKED_IPS: comma-separated list of IPs blocked by middleware
#   (prefer Cloudflare IP Access Rules in production)
# ----------------------------------------------------------------
CRON_SECRET=generate-with-openssl-rand-hex-32
API_KEY_ENCRYPTION_SECRET=generate-with-openssl-rand-hex-32
BLOCKED_IPS=                               # e.g. 1.2.3.4,5.6.7.8

# ----------------------------------------------------------------
# PER-ORIGIN THROTTLE  (optional — safe defaults apply if absent)
# Controls how the queue consumer rate-limits outbound requests
# to the same website origin across concurrent jobs.
#
# HEAVY jobs (analysis.run, monitor.page_check):
#   QUEUE_ORIGIN_HEAVY_CONCURRENCY  — max simultaneous jobs (1–3, default: 1)
#   QUEUE_ORIGIN_HEAVY_DELAY_MS     — min ms between starts (default: 30000)
#   QUEUE_ORIGIN_HEAVY_LEASE_SECONDS — lease TTL in seconds (default: 120)
#
# MEDIUM jobs (monitor.discovery):
#   QUEUE_ORIGIN_MEDIUM_DELAY_MS    — min ms between starts (default: 10000)
#   QUEUE_ORIGIN_MEDIUM_LEASE_SECONDS — lease TTL in seconds (default: 60)
#
# LIGHT jobs (site_connect.verify):
#   QUEUE_ORIGIN_LIGHT_DELAY_MS     — min ms between starts (default: 2000)
#   QUEUE_ORIGIN_LIGHT_LEASE_SECONDS — lease TTL in seconds (default: 30)
#
# Legacy alias (still accepted; overridden by QUEUE_ORIGIN_HEAVY_DELAY_MS):
#   MONITOR_ORIGIN_DELAY_MS
# ----------------------------------------------------------------
QUEUE_ORIGIN_HEAVY_CONCURRENCY=1
QUEUE_ORIGIN_HEAVY_DELAY_MS=30000
QUEUE_ORIGIN_HEAVY_LEASE_SECONDS=120
QUEUE_ORIGIN_MEDIUM_DELAY_MS=10000
QUEUE_ORIGIN_MEDIUM_LEASE_SECONDS=60
QUEUE_ORIGIN_LIGHT_DELAY_MS=2000
QUEUE_ORIGIN_LIGHT_LEASE_SECONDS=30

# ----------------------------------------------------------------
# APP  — set to your production domain before deploying
# ----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
